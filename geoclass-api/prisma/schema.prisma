generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(uuid())
  name          String
  email         String       @unique
  password_hash String
  role          Role         @default(ALUNO)
  ra            String?      @unique
  
  classesTaught Class[]      @relation("ProfessorClasses")
  enrollments   Enrollment[]
  attendances   Attendance[]
  notifications Notification[]

  created_at    DateTime     @default(now())
}

model Class {
  id            String       @id @default(uuid())
  subject       String
  schedule_time String       // Ex: "08:00"
  latitude      Float
  longitude     Float
  radius_meters Int
  active        Boolean      @default(true)
  
  semester      String       @default("2026.1") // Ex: "2026.1"
  room_name     String       @default("Sala Padrão") // Ex: "Lab 1"
  total_classes Int          @default(40) // Quantidade total de aulas previstas
  
  professor_id  String
  professor     User         @relation("ProfessorClasses", fields: [professor_id], references: [id])
  
  enrollments   Enrollment[]
  attendances   Attendance[]

  created_at    DateTime     @default(now())
  temporaryLocs TemporaryClassLocation[]
}

model Enrollment {
  id         String   @id @default(uuid())
  
  student_id String
  student    User     @relation(fields: [student_id], references: [id])
  
  class_id   String
  class      Class    @relation(fields: [class_id], references: [id])

  @@unique([student_id, class_id])
}

model Attendance {
  id                String   @id @default(uuid())
  
  student_id        String
  student           User     @relation(fields: [student_id], references: [id])
  
  class_id          String
  class             Class    @relation(fields: [class_id], references: [id])
  
  date              DateTime @db.Date
  check_in_time     DateTime
  device_id         String?
  status            Status   @default(PRESENTE)
  
  student_latitude  Float?
  student_longitude Float?
  
  is_remote         Boolean  @default(false)
  manual_attendance Boolean  @default(false)
  
  created_at        DateTime @default(now())

  @@unique([student_id, class_id, date])
}

enum Role {
  ALUNO
  PROFESSOR
  COORDENADOR
}

enum Status {
  PRESENTE
  ATRASADO
  FALTA
}

model Room {
  id        String   @id @default(uuid())
  name      String   @unique
  latitude  Float
  longitude Float
}

model TemporaryClassLocation {
  id        String   @id @default(uuid())
  class_id  String
  class     Class    @relation(fields: [class_id], references: [id])
  date      String   // Ex: "2026-05-12"
  room_id   String
  room_name String
  latitude  Float
  longitude Float
  
  @@unique([class_id, date])
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  title      String
  body       String
  read       Boolean  @default(false)
  created_at DateTime @default(now())
}
